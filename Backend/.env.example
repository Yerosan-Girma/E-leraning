# ==========================================
# Application
# ==========================================
PORT=5000
NODE_ENV=production

# ==========================================
# PostgreSQL (Render or Neon free tier)
# ==========================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
# OR individual fields (if not using DATABASE_URL):
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=edulearn_db
DB_SSL=true

# ==========================================
# JWT & Session
# ==========================================
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d
SESSION_SECRET=change_this_to_another_long_random_string

# ==========================================
# CORS — set to your Vercel frontend URL in production
# ==========================================
CORS_ORIGIN=https://your-app.vercel.app

# ==========================================
# Google OAuth (optional)
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback

# ==========================================
# Payment (mock mode for dev)
# ==========================================
PAYMENT_GATEWAY_MODE=mock
